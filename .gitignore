# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real credentials
.env
.env.local
.env.*.local
.env.production

# Firebase service account keys — NEVER commit
*service-account*.json
*serviceAccount*.json
*.key.json

# Firebase debug
.firebase/
firebase-debug.log*

# Firebaserc (contains project ID — use .firebaserc.example)
.firebaserc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
